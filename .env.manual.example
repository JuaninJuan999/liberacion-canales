# Copie este archivo a .env.manual (no lo suba a git si contiene claves reales).
# Luego ejecute: npm run manual:capturas
# con la aplicación en marcha (Laragon o php artisan serve).

MANUAL_BASE_URL=http://127.0.0.1:8000
MANUAL_USERNAME=
MANUAL_PASSWORD=

# Opcional: ruta a Chrome en Windows
# MANUAL_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
