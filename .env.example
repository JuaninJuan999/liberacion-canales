# BD PostgreSQL externa (trazabilidad — solo lectura, módulo Verificación PCC). Opcional.
# Puedes usar POSTGRES_* (ej. POSTGRES_HOST, POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD)
# o el prefijo DB_TRAZABILIDAD_* — si la base no está definida, no se consulta la tabla externa.
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=nombre_bd_trazabilidad
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# DB_TRAZABILIDAD_SEARCH_PATH=trazabilidad_proceso,organizaciones,public

